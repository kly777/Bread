{
	"name": "bread",
	"description": "a extension for reading",
	"private": true,
	"version": "0.1.36",
	"license": "Apache-2.0",
	"type": "module",
	"scripts": {
		"dev": "rollup -c --environment NODE_ENV:development --watch",
		"dev:ext": "web-ext run --browser-console --devtools --source-dir=dist --firefox=firefoxdeveloperedition --start-url www.google.com --start-url wikipedia.org",
		"dev:all": "pnpm run build:dev && concurrently --kill-others \"pnpm run dev\" \"pnpm run dev:ext\"",
		"build": "pnpm clean && rollup -c --environment NODE_ENV:production",
		"build:dev": "rollup -c --environment NODE_ENV:development",
		"compile": "tsc --noEmit",
		"fmt": "biome format --write .",
		"lint": "biome lint .",
		"lint:fix": "biome lint --write .",
		"check": "biome check .",
		"clean": "rm -rf dist/*",
		"sign": "web-ext sign --config=web-ext-config.mjs",
		"sign:unlisted": "web-ext sign --config=web-ext-config.mjs --channel=unlisted",
		"submit": "pnpm run build && pnpm run sign",
		"submit:unlisted": "pnpm run build && pnpm run sign:unlisted"
	},
	"devDependencies": {
		"@babel/core": "^7.29.0",
		"@biomejs/biome": "^2.4.8",
		"@rollup/plugin-alias": "^6.0.0",
		"@rollup/plugin-babel": "^7.0.0",
		"@rollup/plugin-commonjs": "^29.0.2",
		"@rollup/plugin-html": "^2.0.0",
		"@rollup/plugin-node-resolve": "^16.0.3",
		"@rollup/plugin-replace": "^6.0.3",
		"@rollup/plugin-terser": "^1.0.0",
		"@rollup/plugin-typescript": "^12.3.0",
		"@types/chrome": "^0.1.38",
		"@types/firefox-webext-browser": "^143.0.0",
		"babel-preset-solid": "^1.9.10",
		"concurrently": "^9.2.1",
		"postcss": "^8.5.8",
		"postcss-csso": "^6.0.1",
		"postcss-import": "^16.1.1",
		"rollup": "^4.59.0",
		"rollup-plugin-copy": "^3.5.0",
		"rollup-plugin-postcss": "^4.0.2",
		"typescript": "5.9.3",
		"web-ext": "^10.0.0"
	},
	"dependencies": {
		"solid-js": "^1.9.11"
	}
}
